# ============================================================================
# Crux-Webmail — Environment Variables Reference
# ============================================================================
# Copy to .env and customize for your deployment.
# En producción, los secretos sensibles se cargan desde Docker Secrets (secrets/*.txt).
# En desarrollo local, podés definirlos directamente acá.
# ============================================================================

# ------------------------------------------------------------------
# Server
# ------------------------------------------------------------------
NODE_ENV=development
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# ------------------------------------------------------------------
# JWT & Encryption (REQUIRED — mínimo 64 caracteres cada uno)
# ------------------------------------------------------------------
# En producción, usá JWT_SECRET_FILE=/run/secrets/jwt_secret en docker-compose
JWT_SECRET=CHANGE_ME_USE_64_RANDOM_HEX_CHARS_HERE_FOR_JWT_HS256_SIGNING_0123456789ABCDEF
JWT_REFRESH_SECRET=CHANGE_ME_USE_64_RANDOM_HEX_CHARS_HERE_FOR_JWT_REFRESH_HS256_ABCDEF0123456789

# AES-256-GCM key for session encryption (AEAD, mínimo 64 hex chars = 32 bytes)
SESSION_ENCRYPTION_KEY=CHANGE_ME_USE_64_RANDOM_HEX_CHARS_FOR_AEAD_SESSION_ENCRYPTION_KEY_0123456789ABCDEF

# IP hashing salt (mínimo 16 caracteres)
IP_HASH_SALT=CHANGE_ME_IP_SALT_64CHARS_MIN_0123456789ABCDEF

# JWT TTLs
JWT_ACCESS_TTL_MS=300000
JWT_REFRESH_TTL_MS=86400000
JWT_ISSUER=crux-webmail-api
JWT_AUDIENCE=crux-webmail-client

# ------------------------------------------------------------------
# POSTGRESQL
# ------------------------------------------------------------------
POSTGRES_DB=crux_mail
POSTGRES_USER=crux_user
POSTGRES_PASSWORD=CruxDB_2024!xK9mPz#qR7wLnY
POSTGRES_HOST=172.22.0.11
POSTGRES_PORT=5432
POSTGRES_SSL=false

# ------------------------------------------------------------------
# REDIS
# ------------------------------------------------------------------
REDIS_HOST=172.21.0.15
REDIS_PORT=6379
REDIS_PASSWORD=CruxRedis_2024!mK7nPq#sR2xY
REDIS_DB=0

# ------------------------------------------------------------------
# MINIO / S3
# ------------------------------------------------------------------
MINIO_HOST=172.22.0.12
MINIO_PORT=9000
MINIO_ROOT_USER=crux_storage
MINIO_ROOT_PASSWORD=CruxMinIO_2024!sT8vWq#jR3nXpZ

# ------------------------------------------------------------------
# DOVECOT / IMAP
# ------------------------------------------------------------------
DOVECOT_HOST=172.21.0.11
DOVECOT_PORT=993

# ------------------------------------------------------------------
# POSTFIX / SMTP
# ------------------------------------------------------------------
POSTFIX_HOST=172.21.0.10
POSTFIX_PORT=587
POSTFIX_DOMAIN=crux.local

# ------------------------------------------------------------------
# AMAVIS (antivirus + antispam)
# ------------------------------------------------------------------
AMAVIS_HOST=172.21.0.12
AMAVIS_PORT=10024
AMAVIS_CONTROL_PORT=9998

# ------------------------------------------------------------------
# CLAMAV
# ------------------------------------------------------------------
CLAMAV_HOST=172.22.0.10
CLAMAV_PORT=3310

# ------------------------------------------------------------------
# TLS / mTLS
# ------------------------------------------------------------------
TLS_CERT_PATH=./certs/server.crt
TLS_KEY_PATH=./certs/server.key
TLS_CA_PATH=./certs/ca-chain.crt

# ------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# ------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------
RATE_LIMIT_API_RPM=1800
RATE_LIMIT_AUTH_RPM=300
RATE_LIMIT_CONN_PER_IP=20

# ------------------------------------------------------------------
# Session Limits
# ------------------------------------------------------------------
MAX_CONCURRENT_SESSIONS=5

# ------------------------------------------------------------------
# Frontend / CORS
# ------------------------------------------------------------------
FRONTEND_URL=http://localhost:3001
WEBSOCKET_URL=ws://localhost:3000

# ------------------------------------------------------------------
# OpenTelemetry
# ------------------------------------------------------------------
OTEL_ENABLED=false

# ------------------------------------------------------------------
# Network Segments (Internal — DO NOT MODIFY)
# ------------------------------------------------------------------
NETWORK_PUBLIC=172.20.0.0/24
NETWORK_APP=172.21.0.0/24
NETWORK_DATA=172.22.0.0/24
NETWORK_MONITOR=172.23.0.0/24