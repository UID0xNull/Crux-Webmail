# ============================================================================
# Crux-Webmail — Environment Variables Reference
# Copy to .env and customize for your deployment
# ============================================================================

# ------------------------------------------------------------------
# POSTFIX
# ------------------------------------------------------------------
POSTFIX_HOSTNAME=mail.crux.local
POSTFIX_DOMAIN=crux.local
POSTFIX_MAILBOX_SIZE_LIMIT=52428800
POSTFIX_MESSAGE_SIZE_LIMIT=26214400

# ------------------------------------------------------------------
# DOVECOT
# ------------------------------------------------------------------
DOVECOT_SSL_REQUIRED=true
DOVECOT_AUTH_MECHANISMS=plain,login

# ------------------------------------------------------------------
# POSTGRESQL
# ------------------------------------------------------------------
POSTGRES_DB=crux_mail
POSTGRES_USER=crux_user
POSTGRES_PASSWORD=CruxDB_2024!xK9mPz#qR7wLnY
POSTGRES_HOST=172.22.0.11
POSTGRES_PORT=5432

# ------------------------------------------------------------------
# REDIS
# ------------------------------------------------------------------
REDIS_HOST=172.21.0.15
REDIS_PORT=6379
REDIS_PASSWORD=CruxRedis_2024!mK7nPq#sR2xY

# ------------------------------------------------------------------
# MINIO / S3
# ------------------------------------------------------------------
MINIO_ROOT_USER=crux_storage
MINIO_ROOT_PASSWORD=CruxMinIO_2024!sT8vWq#jR3nXpZ
MINIO_HOST=172.22.0.12
MINIO_PORT=9000

# ------------------------------------------------------------------
# AMAVIS
# ------------------------------------------------------------------
AMAVIS_HOST=172.21.0.12
AMAVIS_PORT=10024
AMAVIS_RELEASE_PORT=9998
AMAVIS_SPAM_KILL_LEVEL=15.0
AMAVIS_SA_TAG_LEVEL=2.0

# ------------------------------------------------------------------
# CLAMAV
# ------------------------------------------------------------------
CLAMAV_HOST=172.22.0.10
CLAMAV_PORT=3310

# ------------------------------------------------------------------
# TLS / mTLS
# ------------------------------------------------------------------
TLS_MIN_VERSION=TLSv1.2
TLS_CERT_PATH=/etc/crux-certs/server.crt
TLS_KEY_PATH=/etc/crux-certs/server.key
TLS_CA_PATH=/etc/crux-certs/ca-chain.crt
MTLS_LEAF_VALIDITY_DAYS=7
MTLS_ROTATION_CRON="0 3 * * *"

# ------------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------------
LOG_FORMAT=json
LOG_LEVEL=info
LOG_RETENTION_DAYS=90
LOG_COLD_RETENTION_DAYS=365

# ------------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------------
RATE_LIMIT_API_RPM=1800
RATE_LIMIT_AUTH_RPM=300
RATE_LIMIT_CONN_PER_IP=20

# ------------------------------------------------------------------
# MONITORING
# ------------------------------------------------------------------
GRAFANA_HOST=172.23.0.10
GRAFANA_PORT=3000
LOKI_HOST=172.23.0.11
LOKI_PORT=3100

# ------------------------------------------------------------------
# DNS / MAIL AUTH
# ------------------------------------------------------------------
DKIM_SELECTOR=default
DKIM_ALGORITHM=ed25519
SPF_POLICY=-all
DMARC_POLICY=reject
DNSSEC_ENABLED=true
GREYLISTING_ENABLED=false

# ------------------------------------------------------------------
# NETWORK SEGMENTS (DO NOT MODIFY)
# ------------------------------------------------------------------
NETWORK_PUBLIC=172.20.0.0/24
NETWORK_APP=172.21.0.0/24
NETWORK_DATA=172.22.0.0/24
NETWORK_MONITOR=172.23.0.0/24