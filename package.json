{
  "name": "crux-webmail",
  "version": "1.0.0",
  "description": "Zero-Trust Webmail Enterprise",
  "private": true,
  "workspaces": [
    "src/server",
    "src/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "cd src/server && ts-node-dev --respawn --transpile-only app.ts",
    "dev:web": "cd src/web && next dev -p 3001",
    "build": "npm run build:server && npm run build:web",
    "build:server": "cd src/server && tsc",
    "build:web": "cd src/web && next build",
    "start": "node dist/server/app.js",
    "test": "jest --coverage --detectOpenHandles --no-workspaces",
    "test:unit": "jest --testMatch '**/tests/__tests__/unit/**/*.test.ts' --coverage --no-workspaces",
    "test:integration": "jest --config jest.integration.config.ts --no-workspaces",
    "test:web": "jest --config jest.config.web.ts --coverage --no-workspaces",
    "test:e2e": "jest --testMatch '**/tests/__tests__/e2e/**/*.test.ts' --runInBand --no-workspaces",
    "test:ci": "jest --ci --coverage --no-workspaces",
    "test:watch": "jest --watch --coverage=false --no-workspaces",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --project tests/tsconfig.json --noEmit",
    "docker:build": "docker compose -f docker-compose.yml build",
    "docker:up": "docker compose -f docker-compose.yml up -d",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "release:prepare": "npm run lint && npm run typecheck && npm run test:ci"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.3",
    "fastify-metrics": "^13.2.0",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/session": "^11.1.0",
    "@fastify/static": "^8.0.2",
    "@fastify/swagger": "^9.4.0",
    "@fastify/under-pressure": "^9.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.52.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.56.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.56.0",
    "@opentelemetry/sdk-node": "^0.56.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.30.0",
    "concurrently": "^9.1.0",
    "crypto-js": "^4.2.0",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "next": "^15.1.0",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.9.16",
    "openpgp": "^6.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sequelize": "^6.37.5",
    "simple-imap": "^0.1.6",
    "speakeasy": "^2.0.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.0",
    "@types/speakeasy": "^2.0.10",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.0"
  }
}