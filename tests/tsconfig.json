{
  "extends": "tsconfig.base.json",
  "compilerOptions": {
    "types": ["jest", "node"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": [
    "**/*.ts",
    "src/server/**/*.ts"
  ]
}