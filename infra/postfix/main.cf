# ============================================================================
# Crux-Webmail — Postfix MTA: main.cf
#
# NOTE: This file is bind-mounted as an individual file. postconf -e uses
# atomic rename (write .tmp then rename) which the kernel blocks on bind-
# mounted files (EBUSY). Therefore ALL settings that the vednil/postfix
# entrypoint would set via postconf -e must be present here directly.
# ============================================================================

# ----------------------------------------------------------------------------
# IDENTITY & HOSTNAME  (entrypoint: postconf -e "myhostname = $DOMAIN")
# ----------------------------------------------------------------------------
myhostname = mail.crux.local
mydomain   = crux.local
myorigin   = $mydomain
mydestination = localhost, $myhostname
inet_interfaces = all
inet_protocols  = ipv4

# ----------------------------------------------------------------------------
# SIZE LIMITS
# ----------------------------------------------------------------------------
# 50MB per mailbox, 25MB per message
mailbox_size_limit = 52428800
message_size_limit = 26214400

# ----------------------------------------------------------------------------
# CONNECTION CONTROL
# ----------------------------------------------------------------------------
smtpd_client_connection_rate_limit  = 30
smtpd_client_connection_count_limit = 50
default_process_limit               = 100

# ----------------------------------------------------------------------------
# TLS — identidad propia del servicio firmada por la CA interna
# (postfix.crt, SAN postfix.crux.local; generada por infra/scripts/mtls-setup.sh
#  y montada en /etc/crux-certs). Submission exige TLS (encrypt).
# ----------------------------------------------------------------------------
smtp_tls_security_level  = encrypt
smtpd_tls_security_level = encrypt

smtpd_tls_mandatory_protocols = !SSLv2, !SSLv3, !TLSv1, !TLSv1.1
smtp_tls_mandatory_protocols  = !SSLv2, !SSLv3, !TLSv1, !TLSv1.1
smtpd_tls_mandatory_ciphers   = high
smtp_tls_mandatory_ciphers    = high
smtpd_tls_protocols           = !SSLv2, !SSLv3, !TLSv1, !TLSv1.1
smtp_tls_protocols            = !SSLv2, !SSLv3, !TLSv1, !TLSv1.1

smtpd_tls_cert_file = /etc/crux-certs/postfix.crt
smtpd_tls_key_file  = /etc/crux-certs/postfix.key
# CA interna para validar el cert de cliente del backend (mTLS).
smtpd_tls_CAfile    = /etc/crux-certs/ca-chain.crt
smtpd_tls_ask_ccert = yes

smtp_tls_note_starttls_offer     = yes
smtp_tls_session_cache_database  = btree:${data_directory}/smtp_tls_session_cache
smtpd_tls_session_cache_database = btree:${data_directory}/smtpd_tls_session_cache

# ----------------------------------------------------------------------------
# DOMINIOS Y BUZONES VIRTUALES (PostgreSQL)
# Sin estos mapas Postfix no sabe qué dominios son propios ni valida buzones,
# y rechaza el correo entrante. Las cuentas se resuelven contra la tabla `users`
# del backend; los dominios/alias contra virtual_domains/virtual_aliases.
# ----------------------------------------------------------------------------
virtual_mailbox_domains = pgsql:/etc/postfix/sql/pgsql-virtual-mailbox-domains.cf
virtual_mailbox_maps    = pgsql:/etc/postfix/sql/pgsql-virtual-mailbox-maps.cf
virtual_alias_maps      = pgsql:/etc/postfix/sql/pgsql-virtual-alias-maps.cf

# ----------------------------------------------------------------------------
# DELIVERY → Dovecot via LMTP (socket unix compartido en el spool de Postfix;
# el inet_listener TCP:24 de Dovecot está deshabilitado a propósito).
# ----------------------------------------------------------------------------
virtual_transport = lmtp:unix:private/dovecot-lmtp

lmtp_destination_recipient_limit = 1
lmtp_connect_timeout             = 60s
lmtp_mail_timeout                = 300s
lmtp_pix_workaround_delay_time   = 1s

# ----------------------------------------------------------------------------
# SASL AUTH via Dovecot
# (entrypoint: postconf -e "smtpd_sasl_path = inet:[${DOVECOT_HOST}]:12345")
# ----------------------------------------------------------------------------
smtpd_sasl_type              = dovecot
smtpd_sasl_path              = inet:[dovecot]:12345
smtpd_sasl_auth_enable       = yes
smtpd_sasl_security_options  = noanonymous
smtpd_sasl_tls_security_options = noanonymous

smtpd_relay_restrictions =
    permit_mynetworks,
    permit_sasl_authenticated,
    reject_unauth_destination

# ----------------------------------------------------------------------------
# ANTI-SPOOFING — un cliente autenticado SÓLO puede enviar con un From que
# coincida con su login SASL. El mapa pcre es identidad (sender X → login X),
# así que cada usuario sólo puede enviar como sí mismo. El backend submite con
# la identidad real del usuario (master user de Dovecot), por lo que From==login.
# No afecta el correo entrante (no autenticado).
# ----------------------------------------------------------------------------
smtpd_sender_login_maps = pcre:/etc/postfix/sender_login.pcre
smtpd_sender_restrictions =
    reject_authenticated_sender_login_mismatch,
    permit_mynetworks,
    permit

# ----------------------------------------------------------------------------
# CONTENT FILTER → Amavis
# (entrypoint: postconf -e "content_filter = amavisfeed:[${AMAVIS_HOST}]:10024")
# ----------------------------------------------------------------------------
content_filter = amavisfeed:[amavis-virus]:10024

receive_override_options = no_address_mappings

# ----------------------------------------------------------------------------
# MILTERS — Firma DKIM del correo saliente vía el servicio opendkim (milter
# en :8891). milter_default_action=accept: si opendkim no responde, el correo
# igual sale (sin firmar) en vez de quedar trabado.
# ----------------------------------------------------------------------------
smtpd_milters         = inet:[opendkim]:8891
non_smtpd_milters     = inet:[opendkim]:8891
milter_default_action = accept
milter_protocol       = 6

# ----------------------------------------------------------------------------
# DNS BLACKLISTS
# ----------------------------------------------------------------------------
smtpd_restriction_classes = blacklist_check
blacklist_check =
    reject_rbl_client bl.spamcop.net,
    reject_rbl_client sbl.spamhaus.org,
    reject_rbl_client xbl.spamhaus.org,
    reject_rbl_client zen.spamhaus.org

# ----------------------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------------------
smtpd_client_message_rate_limit   = 80
smtpd_client_recipient_rate_limit = 150

# ----------------------------------------------------------------------------
# HEADER & BODY CHECKS
# ----------------------------------------------------------------------------
header_checks = regexp:/etc/postfix/header_checks
body_checks   = regexp:/etc/postfix/body_checks

# ----------------------------------------------------------------------------
# LOGGING — a stdout para que aparezca en `docker logs` (el entrypoint normal
# lo setea vía postconf -e, pero eso falla por el bind mount de main.cf).
# ----------------------------------------------------------------------------
maillog_file = /dev/stdout
notify_classes = resource, software

# ----------------------------------------------------------------------------
# COMPATIBILITY
# ----------------------------------------------------------------------------
compatibility_level = 3
relayhost =
