{
  "extends": "tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "downlevelIteration": true,
    "baseUrl": ".",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "experimentalDecorators": false,
    "emitDecoratorMetadata": false,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    "noPropertyAccessFromIndexSignature": false,
    "skipLibCheck": true,
    "types": [
      "node",
      "jest"
    ],
    "paths": {
      "@config/*": [
        "config/*"
      ],
      "@modules/*": [
        "modules/*"
      ],
      "@middleware/*": [
        "middleware/*"
      ],
      "@utils/*": [
        "utils/*"
      ],
      "@types/*": [
        "types/*"
      ],
      "@routes/*": [
        "routes/*"
      ],
      "@errors/*": [
        "errors/*"
      ],
      "@models/*": [
        "models/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "build-errors.txt",
    "tsc-errors.*",
    "ts-*.txt"
  ]
}